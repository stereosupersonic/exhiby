-# Utility Bar (thin dark navy bar)
.header-utility-bar
  .container
    .utility-inner
      .header-login{ data: { testid: "header-login" } }
        - if authenticated?
          = link_to admin_root_path, class: "header-login-icon", title: "Admin", data: { testid: "admin-link" } do
            %i.bi.bi-gear
            %span.visually-hidden Admin
          = button_to session_path, method: :delete, class: "header-login-icon header-login-button", title: "Abmelden", data: { testid: "logout-link" } do
            %i.bi.bi-box-arrow-right
            %span.visually-hidden Abmelden
        - else
          = link_to new_session_path, class: "header-login-icon", title: "Anmelden", data: { testid: "login-link" } do
            %i.bi.bi-person
            %span.visually-hidden Anmelden

-# Main Header Bar
%header.header-main{ data: { testid: "site-header" } }
  .container
    .header-inner
      -# Logo (left)
      .header-logo
        = link_to root_path, data: { testid: "logo-link" } do
          = image_tag "logo/Logo-Online-Museum-V10-100.png", alt: "OnlineMuseum Wartenberg", class: "logo-img"

      -# Navigation (center - desktop only)
      %nav.header-nav{ data: { testid: "main-navigation" } }
        = link_to t("navigation.willkommen"), root_path, class: "nav-link-item#{' active' if local_assigns[:active] == :willkommen}", data: { testid: "nav-willkommen" }

        .nav-dropdown{ data: { controller: "dropdown", action: "mouseenter->dropdown#show mouseleave->dropdown#hide" } }
          = link_to t("navigation.kunstschaffende"), artists_path, class: "nav-link-item#{' active' if local_assigns[:active] == :kunstschaffende}", data: { testid: "nav-kunstschaffende" }
          %span.dropdown-arrow
          .dropdown-menu{ data: { dropdown_target: "menu" } }
            = link_to t("navigation.alle_kunstschaffende"), artists_path, class: "dropdown-item"
            - if @nav_artists&.any?
              .dropdown-divider
              - @nav_artists.each do |artist|
                = link_to artist.name, artist_path(artist.slug), class: "dropdown-item"

        .nav-dropdown{ data: { controller: "dropdown", action: "mouseenter->dropdown#show mouseleave->dropdown#hide" } }
          = link_to t("navigation.land_und_leute"), land_und_leute_path, class: "nav-link-item#{' active' if local_assigns[:active] == :land_und_leute}", data: { testid: "nav-land-leute" }
          %span.dropdown-arrow
          .dropdown-menu{ data: { dropdown_target: "menu" } }
            = link_to t("navigation.alle_sammlungen"), land_und_leute_path, class: "dropdown-item"
            - if @nav_collection_categories&.any?
              .dropdown-divider
              - @nav_collection_categories.each do |category|
                = link_to category.name, land_und_leute_path(anchor: category.slug), class: "dropdown-item"

        = link_to t("navigation.ausstellungen"), ausstellungen_path, class: "nav-link-item#{' active' if local_assigns[:active] == :ausstellungen}", data: { testid: "nav-ausstellungen" }
        = link_to t("navigation.archiv"), articles_path, class: "nav-link-item#{' active' if local_assigns[:active] == :archiv}", data: { testid: "nav-archiv" }
        = link_to t("navigation.team"), team_path, class: "nav-link-item#{' active' if local_assigns[:active] == :team}", data: { testid: "nav-team" }

      -# Search (right - desktop only)
      .header-search{ class: "#{'expanded' if params[:q].present?}", data: { testid: "header-search", controller: "search-toggle", "search-toggle-expanded-value": params[:q].present? } }
        = form_with url: search_path, method: :get, local: true, class: "header-search-form", data: { "search-toggle-target": "form" } do |f|
          = label_tag :q, t("search.placeholder"), class: "visually-hidden"
          .input-group.input-group-sm
            = text_field_tag :q, params[:q], class: "form-control header-search-input", placeholder: t("search.placeholder"), data: { testid: "header-search-input", "search-toggle-target": "input" }
            %button.btn.header-search-btn{ type: "submit", data: { testid: "header-search-submit", "search-toggle-target": "icon", action: "click->search-toggle#handleClick" } }
              %i.bi.bi-search

      -# Mobile hamburger
      %button.header-toggler{ type: "button", data: { bs_toggle: "offcanvas", bs_target: "#mobileNav" }, "aria-label": t("navigation.menu") }
        %i.bi.bi-list

-# Mobile Offcanvas Navigation
.offcanvas.offcanvas-end.offcanvas-nav#mobileNav{ tabindex: "-1", "aria-label": t("navigation.menu") }
  .offcanvas-header
    %h5.offcanvas-title OnlineMuseum Wartenberg
    %button.btn-close{ type: "button", data: { bs_dismiss: "offcanvas" }, "aria-label": "Close" }
  .offcanvas-body
    .mobile-search-form
      = form_with url: search_path, method: :get, local: true, class: "d-flex gap-2" do |f|
        = text_field_tag :q, params[:q], class: "form-control", placeholder: t("search.placeholder")
        %button.btn.btn-primary{ type: "submit" }
          %i.bi.bi-search
    = link_to t("navigation.willkommen"), root_path, class: "mobile-nav-link#{' active' if local_assigns[:active] == :willkommen}"
    = link_to t("navigation.kunstschaffende"), artists_path, class: "mobile-nav-link#{' active' if local_assigns[:active] == :kunstschaffende}"
    - if @nav_artists&.any?
      .mobile-nav-sub
        - @nav_artists.each do |artist|
          = link_to artist.name, artist_path(artist.slug), class: "mobile-nav-link"
    = link_to t("navigation.land_und_leute"), land_und_leute_path, class: "mobile-nav-link#{' active' if local_assigns[:active] == :land_und_leute}"
    = link_to t("navigation.ausstellungen"), ausstellungen_path, class: "mobile-nav-link#{' active' if local_assigns[:active] == :ausstellungen}"
    = link_to t("navigation.archiv"), articles_path, class: "mobile-nav-link#{' active' if local_assigns[:active] == :archiv}"
    = link_to t("navigation.team"), team_path, class: "mobile-nav-link#{' active' if local_assigns[:active] == :team}"
