- content_for :title, t("seo.pages.articles.index.title")
- content_for :meta_description, t("seo.pages.articles.index.description")

= render "shared/site_header", active: :archiv

= render "shared/page_header", title: t("articles.index.title"), testid: "articles-hero", title_testid: "articles-heading"

%section.articles-section.py-5{ data: { testid: "articles-section" } }
  .container

    - if @articles.any?
      .row.g-4
        - @articles.each do |article|
          - presenter = ArticlePresenter.new(article)
          .col-md-6.col-lg-4{ data: { testid: "article-card-#{article.slug}" } }
            .content-card
              - if article.cover_media_item&.file&.attached?
                = link_to article_path(article.slug) do
                  = image_tag article.cover_media_item.file.variant(resize_to_limit: [400, 300]), class: "card-img-top", alt: article.title
              .content-card-body
                .content-card-title
                  = link_to article.title, article_path(article.slug)
                - if article.published_at.present?
                  .content-card-meta.mb-2= presenter.formatted_published_at_month_year
                %p.small.text-muted= presenter.excerpt(length: 200)
                = link_to t("articles.index.read_more"), article_path(article.slug), class: "btn btn-sm btn-outline-primary"

      .d-flex.justify-content-center.mt-4
        = will_paginate @articles
    - else
      .text-center.text-muted.py-4{ data: { testid: "no-articles-message" } }
        %p= t("articles.index.no_articles")
