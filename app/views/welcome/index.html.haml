- content_for :title, t("seo.pages.home.title")
- content_for :meta_description, t("seo.pages.home.description")

= render "shared/site_header", active: :willkommen

-# Search Hero
= render "shared/search_hero", testid: "hero-section"

-# Stats Dashboard
= render "welcome/stats_section"

-# Feature Cards Grid
= render "welcome/feature_cards"

-# Picture of the Day
- if @picture_of_the_day && @picture_of_the_day.media_item.file.attached?
  - picture_presenter = PictureOfTheDayPresenter.new(@picture_of_the_day)
  %section.py-5.bg-white{ data: { testid: "hero-section-picture-of-the-day" } }
    .container
      %h2.section-title.text-center.mb-4= t("navigation.bild_des_tages")
      .row.justify-content-center
        .col-md-8.col-lg-6
          .content-card
            = link_to pictures_of_the_day_path do
              = image_tag picture_presenter.hero_image_url, class: "card-img-top", alt: picture_presenter.display_title
            .content-card-body.text-center
              .content-card-title= picture_presenter.display_title
              .content-card-meta
                %i.bi.bi-calendar3.me-1
                = picture_presenter.formatted_display_date_short

-# Recent Articles
- if @recent_articles.any?
  %section.articles-preview.py-5{ data: { testid: "recent-articles-section" } }
    .container
      %h2.section-title.text-center.mb-4= t("welcome.recent_articles.title")

      .row.g-4
        - @recent_articles.each do |article|
          - presenter = ArticlePresenter.new(article)
          .col-md-4{ data: { testid: "recent-article-card-#{article.slug}" } }
            .content-card
              - if article.cover_media_item&.file&.attached?
                = link_to article_path(article.slug) do
                  = image_tag article.cover_media_item.file.variant(resize_to_limit: [400, 300]), class: "card-img-top", alt: article.title
              .content-card-body
                .content-card-title
                  = link_to article.title, article_path(article.slug)
                - if article.published_at.present?
                  .content-card-meta.mb-2= presenter.formatted_published_at_short
                %p.small.text-muted= presenter.excerpt(length: 150)
                = link_to t("articles.index.read_more"), article_path(article.slug), class: "btn btn-sm btn-outline-primary"

      .text-center.mt-4
        = link_to t("welcome.recent_articles.view_all"), articles_path, class: "btn btn-primary", data: { testid: "view-all-articles" }
